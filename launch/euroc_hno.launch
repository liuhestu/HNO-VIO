<launch>
  <arg name="config" default="euroc_mav" />
  <arg name="dataset" default="V1_01_easy" />
  <arg name="config_path" default="$(find hno_vio)/config/$(arg config)/estimator_config.yaml" />
  <arg name="path_gt" default="$(find hno_vio)/ground_truth/euroc_mav/$(arg dataset).txt" />
  <arg name="bag_path" default="/home/sharpa/datasets/euroc/ROSbag/$(arg dataset).bag" />

  <arg name="max_cameras" default="2" />
  <arg name="bag_start" default="0" />
  <arg name="bag_rate" default="1" />
  <arg name="dobag" default="true" />
  <arg name="use_gt_init" default="false" />
  <arg name="use_gt_mapping" default="false" />
  <arg name="rviz" default="true" />

  <node name="run_hno_vio" pkg="hno_vio" type="run_hno_vio" output="screen" clear_params="true" required="true">
    <param name="config_path" type="string" value="$(arg config_path)" />
    <param name="path_gt" type="string" value="$(arg path_gt)" />
    <param name="use_gt_init" type="bool" value="$(arg use_gt_init)" />
    <param name="use_gt_mapping" type="bool" value="$(arg use_gt_mapping)" />

    <param name="topic_imu" value="/imu0" />
    <param name="topic_cam0" value="/cam0/image_raw" />
    <param name="topic_cam1" value="/cam1/image_raw" />
    <param name="num_cams" value="$(arg max_cameras)" />
  </node>

  <group if="$(arg dobag)">
    <node pkg="rosbag" type="play" name="rosbag" args="-d 1 -r $(arg bag_rate) -s $(arg bag_start) $(arg bag_path)" />
  </group>

  <group if="$(arg rviz)">
    <node pkg="rviz" type="rviz" name="rviz" args="-d $(find hno_vio)/launch/hno.rviz" />
  </group>
</launch>
